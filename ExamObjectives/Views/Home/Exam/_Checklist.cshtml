@model CertificationModel

@using System.Diagnostics
@using ExamObjectives.Models.ViewModels
@using Newtonsoft.Json
@using static ExamObjectives.Helpers.BulletHelpers;
@{
    List<Domain> domains = Model.Domains;

    ViewData["Title"] = $"{Model.ExamCode}";
}

<div class="container py-5">
    <div id="saveStatus" class="position-fixed bottom-0 end-0 m-4 badge rounded-pill text-bg-secondary px-3 py-2 d-none">
        Saving...
    </div>

    <div class="text-center mb-5">
        <span class="badge rounded-pill text-bg-primary px-3 py-2 mb-3">
            @Model.ExamCode
        </span>

        <h1 class="display-5 fw-bold mb-2">
            @Model.Exam
        </h1>

        <p class="text-secondary fs-5 mb-0">
            Exam Objectives and Progress Checklist
        </p>
    </div>

    <div class="mb-2">
        <button class="btn btn-success checklist-add-button rounded-pill px-4 py-2"
                type="button"
                data-exam-code="@Model.ExamCode"
                data-item-type="domain">
            Add Domain
        </button>
    </div>

    @if (domains.Count > 0)
    {
        <ul class="nav nav-pills flex-nowrap overflow-auto gap-2 pb-3 mb-2 exam-domain-tabs" id="domainTabs" role="tablist">
            @for (int i = 0; i < domains.Count; i++)
            {
                Domain domain = domains[i];

                <li class="nav-item" role="presentation">
                    <button class="nav-link rounded-pill @(i == 0 ? "active" : "")"
                            id="domain-tab-@domain.Id"
                            data-bs-toggle="tab"
                            data-bs-target="#domain-pane-@domain.Id"
                            type="button"
                            role="tab"
                            aria-controls="domain-pane-@domain.Id"
                            aria-selected="@(i == 0 ? "true" : "false")">
                        @domain.Number @domain.Title
                    </button>
                </li>
            }
        </ul>
        
        <div class="mb-2">
            @{
                int totalCompletedBullets = GetTotalCompletedBulletCount(domains);
                int totalBulletsCount = GetTotalBulletCount(domains);
                int totalProgressPercentage = GetTotalProgressPercentage(domains);
            }

            <div class="progress-summary">
                <div class="d-flex justify-content-between align-items-center small text-secondary mb-2">
                    <span>
                        Total Progress:
                    </span>

                    <span>
                        @totalCompletedBullets / @totalBulletsCount Complete
                    </span>
                </div>

                <div class="progress domain-progress" role="progressbar" aria-valuenow="@totalProgressPercentage" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar" style="width: @totalProgressPercentage%">
                        @totalProgressPercentage%
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-content" id="domainTabsContent">
            @for (int i = 0; i < domains.Count; i++)
            {
                Domain domain = domains[i];

                <section class="tab-pane fade @(i == 0 ? "show active" : "")"
                         id="domain-pane-@domain.Id"
                         role="tabpanel"
                         aria-labelledby="domain-tab-@domain.Id"
                         tabindex="0">
                    <div class="card exam-domain-card border-secondary-subtle shadow-sm rounded-4">
                        <div class="card-body p-4 p-lg-5">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <span class="badge rounded-pill text-bg-dark border-secondary-subtle">
                                            Domain @domain.Number
                                        </span>

                                        <span class="badge rounded-pill text-bg-primary">
                                            @domain.Weight% of Exam
                                        </span>
                                    </div>

                                    <h2 class="h3 fw-bold mb-2">
                                        @domain.Title
                                    </h2>

                                    <p class="text-secondary mb-0">
                                        Review the objectives and check off each completed topic.
                                    </p>

                                    @{
                                        int completedBullets = GetDomainCompletedBulletCount(domain);
                                        int totalBullets = GetDomainBulletCount(domain);
                                        int progressPercentage = GetDomainProgressPercentage(domain);
                                    }

                                    <div class="domain-progress-summary">
                                        <div class="d-flex justify-content-between align-items-center small text-secondary mb-2">
                                            <span>
                                                Domain Progress:
                                            </span>

                                            <span>
                                                @completedBullets / @totalBullets Complete
                                            </span>
                                        </div>

                                        <div class="progress domain-progress" role="progressbar" aria-valuenow="@progressPercentage" aria-valuemin="0" aria-valuemax="100">
                                            <div class="progress-bar" style="width: @progressPercentage%">
                                                @progressPercentage%
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex flex-column flex-sm-row align-items-start gap-2">
                                    <button class="btn btn-outline-secondary btn-sm checklist-edit-button"
                                            type="button"
                                            data-exam-code="@Model.ExamCode"
                                            data-item-type="domain"
                                            data-domain-id="@domain.Id"
                                            data-number="@domain.Number"
                                            data-title="@domain.Title"
                                            data-weight="@domain.Weight"
                                            data-objectives='@Html.Raw(JsonConvert.SerializeObject(domain.Objectives))'>
                                        Edit Domain
                                    </button>

                                    <button class="btn btn-outline-danger btn-sm checklist-delete-button"
                                            type="button"
                                            data-exam-code="@Model.ExamCode"
                                            data-item-type="domain"
                                            data-domain-id="@domain.Id"
                                            data-number="@domain.Number"
                                            data-title="@domain.Title">
                                        Delete Domain
                                    </button>

                                    <div class="form-check form-switch pt-sm-1">
                                        <input class="form-check-input progress-checkbox"
                                               type="checkbox"
                                               id="domain-@domain.Id"
                                               data-exam-code="@Model.ExamCode"
                                               data-item-type="domain"
                                               data-domain-id="@domain.Id"
                                               checked="@domain.Completed"/>

                                        <label class="form-check-label text-secondary" for="@domain.Id">
                                            Domain Complete
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <button class="btn btn-primary btn-sm checklist-add-button"
                                        type="button"
                                        data-exam-code="@Model.ExamCode"
                                        data-item-type="objective"
                                        data-domain-id="@domain.Id">
                                    Add Objective
                                </button>
                            </div>

                            <div class="d-flex flex-column gap-3">
                                @foreach (Objective objective in domain.Objectives)
                                {
                                    <article class="exam-objective-card border border-seondary-subtle rounded-4 p-4">
                                        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3 mb-4">
                                            <div>
                                                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                                                    <span class="badge rounded-pill text-bg-secondary">
                                                        Objective @objective.Number
                                                    </span>
                                                </div>

                                                <h3 class="h5 fw-semibold lh-base mb-0">
                                                    @objective.Title
                                                </h3>
                                            </div>

                                            <div class="d-flex flex-column flex-sm-row align-items-start gap-2">
                                                <button class="btn btn-outline-secondary btn-sm checklist-edit-button"
                                                        type="button"
                                                        data-exam-code="@Model.ExamCode"
                                                        data-item-type="objective"
                                                        data-domain-id="@domain.Id"
                                                        data-objective-id="@objective.Id"
                                                        data-number="@objective.Number"
                                                        data-title="@objective.Title"
                                                        data-bullets='@Html.Raw(JsonConvert.SerializeObject(objective.Bullets))'>
                                                    Edit
                                                </button>

                                                <button class="btn btn-outline-danger btn-sm checklist-delete-button"
                                                        type="button"
                                                        data-exam-code="@Model.ExamCode"
                                                        data-item-type="objective"
                                                        data-domain-id="@domain.Id"
                                                        data-objective-id="@objective.Id">
                                                    Delete
                                                </button>

                                                <div class="form-check form-switch pt-sm-1">
                                                    <input class="form-check-input progress-checkbox"
                                                           type="checkbox"
                                                           id="objective-@domain.Id-@objective.Id"
                                                           data-exam-code="@Model.ExamCode"
                                                           data-item-type="objective"
                                                           data-domain-id="@domain.Id"
                                                           data-objective-id="@objective.Id"
                                                           checked="@objective.Completed"/>

                                                    <label class="form-check-label text-secondary" for="objective-@domain.Id-@objective.Id">
                                                        Objective Complete
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <button class="btn btn-outline-primary btn-sm checklist-add-button"
                                                    type="button"
                                                    data-exam-code="@Model.ExamCode"
                                                    data-item-type="bullet"
                                                    data-domain-id="@domain.Id"
                                                    data-objective-id="@objective.Id">
                                                Add Bullet
                                            </button>
                                        </div>

                                        @if (objective.Bullets.Count > 0)
                                        {
                                            <div class="row g-3">
                                                @for (int bulletIndex = 0; bulletIndex < objective.Bullets.Count; bulletIndex++)
                                                {
                                                    <partial name = "Exam/Partials/_BulletCard"
                                                             model='new BulletCardViewModel 
                                                             {
                                                                 ExamCode = Model.ExamCode ?? "",
                                                                 Domain = domain,
                                                                 Objective = objective,
                                                                 Bullet = objective.Bullets[bulletIndex],
                                                                 BulletIndex = bulletIndex
                                                             }' />
                                                }
                                            </div>
                                        }
                                    </article>
                                }
                            </div>
                        </div>
                    </div>
                </section>
            }
        </div>

        <partial name="Exam/Partials/_ChecklistEditorModal"/>
    }
</div>